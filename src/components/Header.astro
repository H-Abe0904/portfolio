---
import Logo from "../assets/Lusteria.svg";
---

<!-- ナビゲーションバー部分 -->
<div class="navbar bg-base-100 shadow-sm">
	<div class="navbar-start">
		<!-- ドロップダウンメニュー部分 -->
		<div class="dropdown">	
			<div
				tabindex="0"
				role="button"
				class="btn btn-ghost btn-circle"
				aria-label="Menu"
			>
			
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-5 w-5"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
				>
					<!-- ドロップダウンアイコン部分 -->
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M4 6h16M4 12h16M4 18h7"></path>
				</svg>
			</div>
			<!-- ドロップダウンメニューのコンテンツ部分 -->
			<ul
				tabindex="-1"
				class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow"
			>
				<li><a href="/">Homepage</a></li>
				<li><a href="/portfolio">Portfolio</a></li>
				<li><a>About</a></li>
			</ul>
		</div>
	</div>

	<!-- タイトル部分 -->
	<div class="navbar-center w-50 h-25">
		<!-- タイトルとボタン -->
		<a href="/" class="btn btn-ghost text-xl" ><img src={Logo.src} alt="Astro Logo" class="w-50 h-20" /></a>
	</div>
	<div class="navbar-end"></div>
</div>
