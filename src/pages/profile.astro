---
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import Background from "../components/Background.astro";
---

<Layout>
    {/* 💡 必ず Layout の「中」に Header を入れる */}
    <Header />

    <div class="flex flex-col items-center justify-center h-50">
        <h1 class="text-4xl font-bold mb-4 items-center">プロフィール</h1>
    </div>
    <!-- タイムラインの全体 -->
    <ul class="timeline timeline-vertical">
        <!-- 行エリア -->
        <li>
            <!-- タイムラインの先頭 イベント年を記載 -->
            <div class="timeline-start">
                <p>1998</p>
                
            </div>
            <!-- タイムラインの中央アイコンおよびデザイン部分 -->
            <div class="timeline-middle">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-5 w-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>
            <!-- タイムライン部 経歴詳細の記述部分 -->
            <div class="timeline-end timeline-box">
                <!-- 経歴詳細(preタグで複数行に記述) -->
                <pre
                    class="whitespace-pre-line">
                三重県にて生まれる
                幼少期はWindows 95~XPのマシンをおもちゃにしていた
                </pre>
            </div>
            <!-- タイムライン(アイコン部分)の区切り -->
            <hr />
        </li>
        <!-- タイムラインの区切り -->
        <li>
            <hr />
            <div class="timeline-start">2017-2021</div>
            <div class="timeline-middle">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-5 w-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>

            <div class="timeline-end timeline-box">
                <pre
                    class="whitespace-pre-line">
                皇學館大学 文学部 神道学科 卒業
                主に神道の歴史や文化・神社祭式を学ぶ
                </pre>
            </div>
            <hr />
        </li>
        <li>
            <hr />
            <div class="timeline-start">
                <p>2021-2022</p>
            </div>
            <div class="timeline-middle">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-5 w-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>
            <div class="timeline-end timeline-box">
                <pre
                    class="whitespace-pre-line">
                    IoT機器メーカーにて組込ソフトウェアエンジニア(アルバイト)として勤務
                    主にIoT機器のファームウェア開発に従事
                    未経験からのスタートだったが、入社後は積極的に技術を学びながらテスト業務をメインとしてプロジェクトに貢献
                </pre>
            </div>
            <hr />
        </li>
         <li>
            <hr />
            <div class="timeline-start">
                <p>2022-2024</p>
            </div>
            <div class="timeline-middle">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-5 w-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>
            <div class="timeline-end timeline-box">
                <pre
                    class="whitespace-pre-line">
                    基板メーカーにて組込ソフトウェアエンジニアとして勤務
                    主に産業機器製品の制御基板のソフトウェア開発に従事
                    前職で培ったスキルを活かし、開発メンバーとしてプロジェクトに貢献
                </pre>
            </div>
            <hr />
        </li>
        <li>
            <hr />
            <div class="timeline-start">
                <p>2024-現在</p>
            </div>
            <div class="timeline-middle">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-5 w-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>
            <div class="timeline-end timeline-box">
                <pre
                    class="whitespace-pre-line">
                商社にて社内SEとして勤務
                主に社内システムの運用・保守およびインフラの管理・運用に従事
                社内システムの改善や新規システムの導入プロジェクトに参加し、業務効率化やセキュリティ強化に貢献
                </pre>
            </div>
        </li>
    </ul>
</Layout>
<Background />
