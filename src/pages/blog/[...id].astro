---
// src/pages/blog/[...id].astro
import { getCollection, render } from 'astro:content'; // renderをインポート
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id }, // slug ではなく id
    props: { post },
  }));
}

const { post } = Astro.props;
// render(post) を使って本文を変換する (最新の書き方)
const { Content } = await render(post); 
---


<Layout title={post.data.title}>
  <Header />
  <div class="max-w-3xl mx-auto py-10 px-4">
    <article>
      <header class="mb-10 text-center">
        {post.data.thumbnail && (
          <img 
            src={post.data.thumbnail} 
            alt={post.data.title} 
            class="w-full h-64 object-cover rounded-xl shadow-lg mb-8"
          />
        )}

        <h1 class="text-5xl font-extrabold mb-4 leading-tight">{post.data.title}</h1>

        {post.data.tags && (
          <div class="flex justify-center gap-2 mb-4">
            {post.data.tags.map((tag: string) => (
              <span class="badge badge-outline">{tag}</span>
            ))}
          </div>
        )}

        <div class="divider"></div> 
        <time class="italic opacity-60">{post.data.pubDate?.toLocaleDateString()}</time>
      </header>

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style is:global>
  /* 記事内の画像すべてに角丸と影をつける */
  .prose img {
    border-radius: 0.75rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    margin-left: auto;
    margin-right: auto;
  }
</style>
