---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Background from "../components/background.astro";
---

<script>
    import emailjs from "@emailjs/browser";
    const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
    const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
    const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    const loader = document.getElementById("loader");
    const successMsg = document.getElementById("success-msg");

    form?.addEventListener("submit", (e) => {
        e.preventDefault();

        // UIの状態変更
        btn.disabled = true;
        loader?.classList.remove("hidden");

        // EmailJSでフォーム送信
        emailjs
            .sendForm(SERVICE_ID, TEMPLATE_ID, form, PUBLIC_KEY)
            .then(() => {
                successMsg?.classList.remove("hidden");
                form.reset();
            })
            .catch((error) => {
                alert("送信に失敗しました: " + JSON.stringify(error));
            })
            .finally(() => {
                btn.disabled = false;
                loader?.classList.add("hidden");
            });
    });
</script>

<Layout title="Contact | Portfolio">
    <Header />
    <main class="max-w-2xl mx-auto px-4 py-16">
        <div class="text-center mb-12">
            <h1 class="text-4xl font-bold mb-4">お問い合わせフォーム</h1>
            <p class="text-base-content/70">
                お仕事の依頼やご相談など、お気軽にお問い合わせください。
            </p>
        </div>

        <!-- フォームカード -->
        <!-- フォーム全体を中央に寄せるためのコンテナ -->
        <div
            class="card bg-base-100 shadow-2xl border border-base-200 max-w-xl mx-auto"
        >
            <form id="contact-form" class="card-body gap-6">
                <!-- 各入力項目を flex で横並びにし、ラベル幅を固定する -->

                <!-- ご氏名 -->
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                    <label class="label md:w-32 shrink-0" for="user_name">
                        <span class="label-text font-semibold">ご氏名</span>
                    </label>
                    <input
                        type="text"
                        name="user_name"
                        id="user_name"
                        placeholder="山田 太郎"
                        class="input input-bordered w-full focus:input-primary"
                        required
                    />
                </div>

                <!-- メールアドレス -->
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                    <label class="label md:w-32 shrink-0" for="user_email">
                        <span class="label-text font-semibold"
                            >メールアドレス</span
                        >
                    </label>
                    <input
                        type="email"
                        name="user_email"
                        id="user_email"
                        placeholder="email@example.com"
                        class="input input-bordered w-full focus:input-primary"
                        required
                    />
                </div>

                <!-- 本文 -->
                <div class="flex flex-col md:flex-row gap-2">
                    <label class="label md:w-32 shrink-0 pt-3" for="message">
                        <span class="label-text font-semibold">本文</span>
                    </label>
                    <textarea
                        name="message"
                        id="message"
                        class="textarea textarea-bordered w-full h-32 focus:textarea-primary"
                        placeholder="メッセージを入力してください。"
                        required></textarea>
                </div>

                <!-- 送信ボタンを右側に寄せる、または幅いっぱいに -->
                <div class="flex md:ml-34 mt-4 justify-center md:justify-end">
                    <button
                        type="submit"
                        id="submit-btn"
                        class="btn btn-primary px-8 flex items-center gap-2"
                    >
                        送信
                        <span id="loader" class="loading loading-spinner hidden"
                        ></span>
                    </button>
                </div>
            </form>
        </div>
    </main>
</Layout>
<Background />
