---
import "../styles/global.css";

const { pageTitle } = Astro.props;
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
    </head>
    <body>
        <header>
			<!-- ナビゲーションバー部分(高さ調整のためコメントアウト) -->
             <!-- <div class="navbar bg-base-100 shadow-sm min-h-[3rem] py-0"> -->
                 </div>
        </header>

        <main>
            <slot /> </main>
    </body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
